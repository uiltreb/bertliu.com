<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manufacturing Stack — Bert Liu</title>
    <meta
      name="description"
      content="How a hardware product moves through Taiwan’s production stack — material, forming, machining, surface finishing, inspection, and assembly — and where problems carry across layers."
    />
    <link rel="canonical" href="https://bertliu.com/manufacturing-stack" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
