    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Manufacturing Stack — Bert Liu" />
    <meta
      name="twitter:description"
      content="How a hardware product moves through Taiwan’s production stack — material, forming, machining, surface finishing, inspection, and assembly — and where problems carry across layers."
    />
