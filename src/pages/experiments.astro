<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Experiments — Bert Liu</title>
    <style>
      :root {
        --bg: #f7f4ed;
        --text: #1f1f1b;
        --muted: #4e4a42;
        --line: #d8d2c5;
      }

      * {
        box-sizing: border-box;
      }

      html {
        overflow-y: scroll;
        scrollbar-gutter: stable;
      }
      
      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.65;
      }

      .page {
        width: min(1100px, 100%);
        margin: 0 auto;
        padding: 40px 24px 80px;
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        column-gap: 56px;
      }

      nav {
        position: sticky;
        top: 48px;
        align-self: start;
        width: 180px;
      }

      nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      nav a {
        color: var(--muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        padding-bottom: 2px;
      }

      nav a:hover,
      nav a:focus-visible {
        color: var(--text);
        border-bottom-color: var(--line);
      }

      main {
        grid-column: 2;
        max-width: 750px;
      }

      .intro {
        padding: 0 0 28px;
      }

      .intro-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.1rem, 5vw, 3rem);
        font-weight: 500;
        letter-spacing: 0.01em;
      }

      .intro-links {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
      }

      .intro-links a {
        color: var(--muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        padding-bottom: 1px;
      }

      .intro-links a:hover,
      .intro-links a:focus-visible {
        color: var(--text);
        border-bottom-color: var(--line);
      }

      .intro p,
      p {
        margin: 0;
        color: var(--muted);
      }

      .intro p {
        max-width: 60ch;
        font-size: clamp(1.05rem, 2.2vw, 1.28rem);
      }

      section {
        padding: 36px 0;
        border-top: 1px solid var(--line);
      }

      h2 {
        margin: 0 0 12px;
        font-size: 1.45rem;
        font-weight: 500;
      }

      .experiment-list {
        display: grid;
        gap: 28px;
      }

      .experiment h3 {
        margin: 0 0 6px;
        font-size: 1.25rem;
      }

      @media (max-width: 900px) {
        .page {
          display: block;
          padding: 20px 20px 56px;
        }

        nav {
          position: static;
          width: auto;
          margin-bottom: 24px;
          border-bottom: 1px solid var(--line);
          padding-bottom: 12px;
        }

        nav ul {
          flex-direction: row;
          flex-wrap: wrap;
          gap: 10px 18px;
        }

        .intro-head {
          align-items: flex-end;
          flex-wrap: wrap;
          margin-bottom: 10px;
        }

        section {
          padding: 28px 0;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <nav aria-label="Main navigation">
        <ul>
          <li><a href="/">Field Notes</a></li>
          <li><a href="/capabilities">Capabilities</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <main>
        <header class="intro">
          <div class="intro-head">
            <h1>Bert Liu</h1>
            <div class="intro-links" aria-label="Social links">
              <a
                href="https://www.linkedin.com/in/bert-liu-8b3a2323/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn">in</a
              >
              <a
                href="https://www.instagram.com/bertbuilds/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram">ig</a
              >
              <a href="mailto:bert@bertliu.com" aria-label="Email">✉</a>
            </div>
          </div>
          <p>Manufacturing in Taiwan. Notes on factories, health, and experiments.</p>
        </header>

        <section>
          <h2>Experiments</h2>
          <p>
            Small experiments in health, routines, food, tools, product ideas,
            and living systems.
          </p>
        </section>

        <section class="experiment-list">
          <div class="experiment">
            <h3>Health</h3>
            <p>
              Training, Pilates, nutrition, sleep, recovery, and practical systems
              for staying consistent.
            </p>
          </div>

          <div class="experiment">
            <h3>Food</h3>
            <p>
              High-protein baking, simple meals, ingredient testing, and repeatable
              cooking routines.
            </p>
          </div>

          <div class="experiment">
            <h3>Operating Systems</h3>
            <p>
              Daily routines, study systems, tools, website building, and life
              structure experiments.
            </p>
          </div>

          <div class="experiment">
            <h3>Product Ideas</h3>
            <p>
              Small prototypes, manufacturing ideas, lifestyle products, and
              experiments that could turn into real businesses.
            </p>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>