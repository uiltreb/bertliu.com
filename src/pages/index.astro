    <script>
      const carousels = Array.from(
        document.querySelectorAll("[data-carousel]"),
      );

      carousels.forEach((carouselRoot) => {
        const carouselImage = carouselRoot.querySelector(
          "[data-carousel-image]",
        ) as HTMLImageElement | null;
        const carouselVideo = carouselRoot.querySelector(
          "[data-carousel-main-video]",
        ) as HTMLElement | null;
        const carouselThumbs = Array.from(
          carouselRoot.querySelectorAll("[data-carousel-thumb]"),
        );
        const carouselStatus = carouselRoot.querySelector(
          "[data-carousel-status]",
        );

        const carouselItems = carouselThumbs.map((thumb) => {
          const img = thumb.querySelector("img") as HTMLImageElement | null;

          return {
            type: thumb.getAttribute("data-media-type") || "image",
            src: img?.getAttribute("src") ?? "",
            alt: img?.getAttribute("alt") ?? "",
          };
        });

        let carouselIndex = 0;

        function renderCarousel() {
          if (!carouselStatus || carouselItems.length === 0) return;

          const current = carouselItems[carouselIndex];

          if (current.type === "video" && carouselVideo) {
            carouselVideo.removeAttribute("hidden");
            if (carouselImage) carouselImage.setAttribute("hidden", "");
          } else if (carouselImage) {
            carouselImage.src = current.src;
            carouselImage.alt = current.alt;
            carouselImage.removeAttribute("hidden");
            if (carouselVideo) carouselVideo.setAttribute("hidden", "");
          }

          carouselStatus.textContent = `${carouselIndex + 1} / ${carouselItems.length}`;

          carouselThumbs.forEach((thumb, index) => {
            thumb.classList.toggle("active", index === carouselIndex);
          });
        }

        carouselThumbs.forEach((thumb, index) => {
          thumb.addEventListener("click", () => {
            carouselIndex = index;
            renderCarousel();
          });
        });

        renderCarousel();
      });

      const videoOverlay = document.querySelector("[data-video-overlay]");
      const videoPlayer = videoOverlay?.querySelector(
        "[data-video-player]",
      ) as HTMLVideoElement | null;
      const overlayImage = videoOverlay?.querySelector(
        "[data-overlay-image]",
      ) as HTMLImageElement | null;
      const videoOpeners = Array.from(
        document.querySelectorAll("[data-video-open]"),
      );
      const imageOpeners = Array.from(
        document.querySelectorAll("[data-carousel-image]"),
      );

      function closeOverlay() {
        if (!videoOverlay) return;
        if (videoPlayer) {
          videoPlayer.pause();
          videoPlayer.removeAttribute("src");
          videoPlayer.load();
          videoPlayer.setAttribute("hidden", "");
        }
        if (overlayImage) {
          overlayImage.removeAttribute("src");
          overlayImage.setAttribute("hidden", "");
        }
        videoOverlay.setAttribute("hidden", "");
        document.body.style.overflow = "";
      }

      videoOpeners.forEach((opener) => {
        opener.addEventListener("click", () => {
          if (!videoOverlay || !videoPlayer) return;
          const src = opener.getAttribute("data-video-src");
          if (!src) return;
          if (overlayImage) overlayImage.setAttribute("hidden", "");
          videoPlayer.removeAttribute("hidden");
          videoPlayer.src = src;
          videoOverlay.removeAttribute("hidden");
          document.body.style.overflow = "hidden";
          videoPlayer.play().catch(() => {});
        });
      });

      imageOpeners.forEach((el) => {
        const img = el as HTMLImageElement;
        img.setAttribute("role", "button");
        img.setAttribute("tabindex", "0");
        img.setAttribute("aria-label", "Open image in full view");
        const open = () => {
          if (!videoOverlay || !overlayImage) return;
          const src = img.getAttribute("src") ?? "";
          const alt = img.getAttribute("alt") ?? "";
          if (!src) return;
          if (videoPlayer) videoPlayer.setAttribute("hidden", "");
          overlayImage.src = src;
          overlayImage.alt = alt;
          overlayImage.removeAttribute("hidden");
          videoOverlay.removeAttribute("hidden");
          document.body.style.overflow = "hidden";
        };
        img.addEventListener("click", open);
        img.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            open();
          }
        });
      });

      videoOverlay
        ?.querySelector("[data-video-close]")
        ?.addEventListener("click", closeOverlay);

      videoOverlay?.addEventListener("click", (event) => {
        if (event.target === videoOverlay) closeOverlay();
      });

      document.addEventListener("keydown", (event) => {
        if (
          event.key === "Escape" &&
          videoOverlay &&
          !videoOverlay.hasAttribute("hidden")
        ) {
          closeOverlay();
        }
      });
    </script>
  </body>
</html>
